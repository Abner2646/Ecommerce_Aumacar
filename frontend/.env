REACT_APP_API_URL=http://localhost:3001/api
PORT=5173

# Frontend URL (para CORS)
FRONTEND_URL=http://localhost:3000

# JWT
JWT_SECRET=tu_secret_super_secreto_cambialo_en_produccion
JWT_EXPIRE=7d

# Tiempos de expiración de tokens
#JWT_EXPIRE=15m          # Access token (corto para seguridad)
JWT_REFRESH_EXPIRE=7d   # Refresh token (más largo para conveniencia)

# ==================== SESSION ====================
# IMPORTANTE: Cambiar en producción
# Generar con: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=cambiar_este_secreto_de_sesion_en_produccion

# ==================== REDIS (Opcional pero recomendado) ====================
# Si no está configurado, se usará fallback en memoria (no recomendado para producción)
REDIS_URL=redis://localhost:6379
# O con autenticación:
# REDIS_URL=redis://:password@localhost:6379

# ==================== CORS ====================
# Orígenes permitidos (separados por coma)
FRONTEND_URL=http://localhost:3000
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173,http://localhost:8081

# ==================== RATE LIMITING ====================
# Valores por defecto si no se especifican
RATE_LIMIT_WINDOW_MS=900000     # 15 minutos
RATE_LIMIT_MAX_REQUESTS=100     # Máximo requests por ventana

# ==================== SECURITY ====================
# Bloqueo de cuenta por intentos fallidos
MAX_LOGIN_ATTEMPTS=5            # Intentos antes de bloquear
ACCOUNT_LOCK_TIME_MINUTES=30    # Tiempo de bloqueo en minutos

# Política de contraseñas
PASSWORD_MIN_LENGTH=8
PASSWORD_REQUIRE_UPPERCASE=true
PASSWORD_REQUIRE_LOWERCASE=true
PASSWORD_REQUIRE_NUMBER=true
PASSWORD_REQUIRE_SYMBOL=true

# ==================== 2FA ====================
# Nombre que aparecerá en la app autenticadora
TOTP_ISSUER=Concesionaria

# ==================== EMAIL (Para password reset - opcional) ====================
# Configurar si se quiere enviar emails reales
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=tu_email@gmail.com
SMTP_PASS=tu_app_password
EMAIL_FROM=noreply@concesionaria.com


# ==================== GOOGLE OAUTH (Opcional) ====================
GOOGLE_CLIENT_ID=tu_google_client_id
GOOGLE_CLIENT_SECRET=tu_google_client_secret
GOOGLE_CALLBACK_URL=http://localhost:3001/api/auth/google/callback

# ==================== LOGGING ====================
LOG_LEVEL=debug         # debug, info, warn, error
LOG_FORMAT=dev          # dev, combined, common

# ==================== NOTAS DE SEGURIDAD ====================
# 1. NUNCA commitear el archivo .env real a git
# 2. En producción, usar variables de entorno del sistema o secrets manager
# 3. Regenerar JWT_SECRET y SESSION_SECRET periódicamente
# 4. Usar HTTPS en producción
# 5. Configurar Redis con autenticación en producción