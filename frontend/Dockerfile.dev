# frontend/Dockerfile.dev
FROM node:18-alpine

# Install hot reload tools
RUN apk add --no-cache git

WORKDIR /app

# Environment variables for hot reload
ENV CHOKIDAR_USEPOLLING=true
ENV WATCHPACK_POLLING=true
ENV FAST_REFRESH=true

# Copy package.json first to take advantage of Docker caching
COPY package*.json ./

# Install dependencies (--legacy-peer-deps needed because react-scripts@5
# requires TypeScript ^3||^4 while i18next@25+ declares TypeScript 5 as peer)
RUN npm install --legacy-peer-deps

# Copy source code
COPY . .

# Expose port
EXPOSE 3000

# Command with hot reload enabled (sin --host porque se configura con ENV)
CMD ["npm", "start"]